# Secrets & env
.env
.env.*
!.env.example

# Dependencies & build output
node_modules/
dist/
*.tsbuildinfo

# Database data
postgresql/data/

# Deployed static web (rebuilt via pnpm deploy:web)
react/app/

# TLS private keys (keep example configs only)
infra/certs/*.pem
infra/certs/*.key

# OS & IDE
.DS_Store
Thumbs.db
*.log
npm-debug.log*
pnpm-debug.log*

# Expo / mobile
.expo/
*.jks
*.p8
*.p12
*.mobileprovision

# PWA generated assets (regenerated on build)
leo-os/apps/web/public/pwa-*.png
leo-os/apps/web/public/apple-touch-icon-*.png
leo-os/apps/web/public/maskable-icon-*.png
leo-os/apps/web/public/favicon.ico

# Cursor local (optional)
.cursor/
