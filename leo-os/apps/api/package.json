{
  "name": "@leo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "pnpm --filter @leo/db run build && node build.mjs",
    "start": "node --enable-source-maps dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@leo/db": "workspace:*",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "mrz": "^4.2.1",
    "multer": "^1.4.5-lts.2",
    "pdf2pic": "^3.2.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.16.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "sharp": "^0.34.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.0",
    "@types/pdfkit": "^0.17.6",
    "esbuild": "^0.25.5",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  }
}
