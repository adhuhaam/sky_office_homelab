{
  "expo": {
    "name": "SKY OFFICE",
    "slug": "leo-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "leo-admin",
    "userInterfaceStyle": "light",
    "backgroundColor": "#000000",
    "icon": "./assets/images/logo.png",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leo.admin"
    },
    "android": {
      "package": "com.leo.admin",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SKY OFFICE to access photos for passport upload.",
          "cameraPermission": "Allow SKY OFFICE to use the camera for passport upload."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "adhuhaam",
    "extra": {
      "eas": {
        "projectId": "930da1e8-b735-40c9-b04a-f71604dbceeb"
      }
    }
  }
}
