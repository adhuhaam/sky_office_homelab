# Passport OCR — DeepSeek-compatible vision API (OpenAI chat/completions format).
# Official api.deepseek.com is text-only; for image OCR use a vision endpoint such as
# self-hosted DeepSeek-OCR (vLLM) and set DEEPSEEK_OCR_BASE_URL=http://host:8000/v1
DEEPSEEK_API_KEY=
DEEPSEEK_OCR_BASE_URL=https://api.deepseek.com
DEEPSEEK_OCR_MODEL=deepseek-v4-flash
