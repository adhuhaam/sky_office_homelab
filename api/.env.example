SESSION_SECRET=change-me-to-a-long-random-string
SUPERUSER_EMAIL=admin@leo.local
SUPERUSER_PASSWORD=change-me
NODE_ENV=production
PORT=8080
CORS_ORIGIN=http://100.126.222.96:3000
COOKIE_SECURE=false
